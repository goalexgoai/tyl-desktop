{
  "name": "textyourlist",
  "version": "1.0.51",
  "description": "Text Your List — Send personal texts to your list",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "test": "jest",
    "test:unit": "jest tests/unit.test.js",
    "test:api": "jest tests/api.test.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "cookie-parser": "^1.4.6",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.0.3",
    "electron-updater": "^6.8.3",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "session-file-store": "^1.5.0",
    "stripe": "^14.21.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "build": {
    "appId": "com.textyourlist.app",
    "productName": "Text Your List",
    "asar": true,
    "asarUnpack": [
      "server.js",
      "db.js",
      "send-mac.js",
      "send-windows.js",
      "node_modules/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "db.js",
      "send-mac.js",
      "send-windows.js",
      "assets/**",
      "public/**",
      "companion/**",
      "node_modules/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg"
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "goalexgoai",
      "repo": "tyl-desktop"
    }
  }
}
